# Only ship the skills and installer — exclude everything else

# Dev/build artifacts
node_modules/
.venv/
.pytest_cache/
*.pyc
__pycache__/
dist/
build/
uv.lock
pyproject.toml

# Personal/local files
.env
.mcp.json
.claude/settings.json
.claude/settings.local.json
project-context.md
CLAUDE.md
fred-data/

