.claude/skills/bmad-*/
.claude/vendor/

# BMad build/config/output (not needed at runtime)
_bmad/
_bmad-output/

# In-progress skills/ shadow copies (canonical is .claude/skills/)
skills/

# Daemon (not part of npx install)
daemon/

# Git
.git/
.gitignore
